DATABASE_URL=postgres://reveste:reveste@host:5432/reveste?sslmode=require
HTTP_ADDRESS=:8080
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_SEU_STORE_ID_SEU_TOKEN
BLOB_PUBLIC_HOST=SEU_STORE.public.blob.vercel-storage.com
# Defina como true apenas quando a API estiver atrás de um proxy reverso confiável.
# Nesse caso, X-Forwarded-Proto e X-Forwarded-For passam a ser considerados.
TRUST_PROXY=false
# Intervalo do processador de expiracoes de checkout e prazos de envio.
JOBS_INTERVAL=1m
# Cotacao de frete via Melhor Envio. Sem MELHORENVIO_TOKEN, o checkout usa um frete fixo
# de contingencia. URL padrao aponta para o sandbox; em producao use https://www.melhorenvio.com.br.
MELHORENVIO_TOKEN=
MELHORENVIO_URL=https://sandbox.melhorenvio.com.br
# Identificacao da integracao exigida pelo Melhor Envio (nome e e-mail de contato).
MELHORENVIO_USER_AGENT=ReVeste (contato@reveste.com.br)
# Pagamento via Mercado Pago. Sem MERCADOPAGO_ACCESS_TOKEN, o checkout usa o provedor simulado
# (aprova na hora) e o endpoint de webhook nao e exposto. Use credenciais de TESTE no sandbox.
# A URL padrao serve para sandbox e producao (o ambiente e definido pelo token).
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_URL=https://api.mercadopago.com
# URL publica que o Mercado Pago chamara ao mudar o status do pagamento. Em desenvolvimento,
# exponha a porta local com um tunel (ex.: ngrok) e use https://SEU_TUNEL/webhooks/pagamento.
MERCADOPAGO_NOTIFICATION_URL=
